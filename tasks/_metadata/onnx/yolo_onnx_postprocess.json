{
  "id": "yolo_onnx_postprocess",
  "category": "onnx",
  "display_name": "Yolo Onnx Postprocess",
  "description": "Postprocess YOLO ONNX model output to extract detections with NMS.",
  "inputs": {
    "raw_output": {
      "type": "np.ndarray",
      "required": true,
      "description": "Input parameter: raw_output"
    },
    "original_shape": {
      "type": "tuple",
      "required": true,
      "description": "Input parameter: original_shape"
    },
    "confidence_threshold": {
      "type": "float",
      "required": false,
      "description": "Input parameter: confidence_threshold",
      "default": 0.25
    },
    "iou_threshold": {
      "type": "float",
      "required": false,
      "description": "Input parameter: iou_threshold",
      "default": 0.45
    },
    "target_size": {
      "type": "int",
      "required": false,
      "description": "Input parameter: target_size",
      "default": 640
    }
  },
  "outputs": {
    "detections": {
      "type": "any",
      "description": "Output: detections"
    }
  },
  "dependencies": {
    "python": [
      "numpy>=1.24.0"
    ],
    "system": []
  },
  "version": "1.0.0",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-02-11",
  "updated_at": "2026-03-03",
  "tags": [
    "onnx"
  ]
}
