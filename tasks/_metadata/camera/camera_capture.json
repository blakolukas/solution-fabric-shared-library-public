{
  "id": "camera_capture",
  "category": "camera",
  "display_name": "Camera Capture",
  "description": "Capture a single frame from a camera device.",
  "is_collapsed": false,
  "inputs": {
    "camera_index": {
      "type": "int",
      "required": false,
      "description": "Input parameter: camera_index",
      "default": 0
    },
    "width": {
      "type": "int",
      "required": false,
      "description": "Input parameter: width",
      "default": 1280
    },
    "height": {
      "type": "int",
      "required": false,
      "description": "Input parameter: height",
      "default": 720
    },
    "warmup_frames": {
      "type": "int",
      "required": false,
      "description": "Input parameter: warmup_frames",
      "default": 3
    }
  },
  "outputs": {
    "frame": {
      "type": "image",
      "description": "Output: frame"
    },
    "metadata": {
      "type": "json",
      "description": "Output: metadata"
    }
  },
  "dependencies": {
    "python": [
      "numpy>=1.24.0",
      "opencv-python>=4.8.0"
    ],
    "system": []
  },
  "version": "1.0.0",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-02-11",
  "updated_at": "2026-03-06",
  "tags": [
    "camera"
  ]
}
