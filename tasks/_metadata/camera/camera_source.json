{
  "id": "camera_source",
  "category": "camera",
  "display_name": "Camera Source",
  "description": "Create a frame generator from a camera device.",
  "inputs": {
    "camera_index": {
      "type": "int",
      "required": false,
      "description": "Input parameter: camera_index",
      "default": 0
    },
    "target_fps": {
      "type": "float",
      "required": false,
      "description": "Input parameter: target_fps",
      "default": 30.0
    },
    "width": {
      "type": "int",
      "required": false,
      "description": "Input parameter: width",
      "default": 1280
    },
    "height": {
      "type": "int",
      "required": false,
      "description": "Input parameter: height",
      "default": 720
    }
  },
  "outputs": {
    "frame_generator": {
      "type": "generator",
      "description": "Output: frame_generator"
    },
    "metadata": {
      "type": "json",
      "description": "Output: metadata"
    }
  },
  "dependencies": {
    "python": [
      "opencv-python>=4.8.0"
    ],
    "system": []
  },
  "version": "1.0.0",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-02-11",
  "updated_at": "2026-02-19",
  "tags": [
    "camera"
  ]
}
