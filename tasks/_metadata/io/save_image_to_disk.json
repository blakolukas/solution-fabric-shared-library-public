{
  "id": "save_image_to_disk",
  "category": "io",
  "display_name": "Save Image to Disk",
  "description": "Save an image array to disk.",
  "inputs": {
    "image_array": {
      "type": "any",
      "required": true,
      "description": "Input parameter: image_array"
    },
    "save_path": {
      "type": "str",
      "required": false,
      "description": "Input parameter: save_path",
      "default": "."
    },
    "save_name": {
      "type": "str",
      "required": false,
      "description": "Input parameter: save_name",
      "default": "output.png"
    }
  },
  "outputs": {
    "saved_image_path": {
      "type": "any",
      "description": "Output: saved_image_path"
    }
  },
  "dependencies": {
    "python": [
      "numpy>=1.24.0",
      "opencv-python>=4.8.0"
    ],
    "system": []
  },
