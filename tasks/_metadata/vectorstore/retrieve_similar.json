{
  "id": "retrieve_similar",
  "category": "vectorstore",
  "display_name": "Retrieve Similar",
  "description": "Retrieve similar documents from a collection.",
  "inputs": {
    "collection": {
      "type": "object",
      "required": true,
      "description": "Input parameter: collection"
    },
    "query_embedding": {
      "type": "list",
      "required": true,
      "description": "Input parameter: query_embedding"
    },
    "top_k": {
      "type": "int",
      "required": false,
      "description": "Input parameter: top_k",
      "default": 5
    },
    "score_threshold": {
      "type": "Optional[float]",
      "required": false,
      "description": "Input parameter: score_threshold",
      "default": null
    }
  },
  "outputs": {
    "documents": {
      "type": "list",
      "description": "Output: documents"
    },
    "scores": {
      "type": "list",
      "description": "Output: scores"
    }
  },
