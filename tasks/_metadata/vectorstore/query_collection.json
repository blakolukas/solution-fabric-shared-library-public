{
  "id": "query_collection",
  "category": "vectorstore",
  "display_name": "Query Collection",
  "description": "Query a ChromaDB collection for similar documents.",
  "inputs": {
    "collection": {
      "type": "object",
      "required": true,
      "description": "Input parameter: collection"
    },
    "query_embeddings": {
      "type": "Optional[List[list]]",
      "required": false,
      "description": "Input parameter: query_embeddings",
      "default": null
    },
    "query_texts": {
      "type": "Optional[List[str]]",
      "required": false,
      "description": "Input parameter: query_texts",
      "default": null
    },
    "n_results": {
      "type": "int",
      "required": false,
      "description": "Input parameter: n_results",
      "default": 5
    },
    "where": {
      "type": "Optional[Dict[str, Any]]",
      "required": false,
      "description": "Input parameter: where",
      "default": null
    },
    "include": {
      "type": "Optional[List[str]]",
      "required": false,
      "description": "Input parameter: include",
      "default": null
    }
  },
  "outputs": {
    "documents": {
      "type": "list",
      "description": "Output: documents"
    },
    "metadatas": {
      "type": "list",
      "description": "Output: metadatas"
    },
    "distances": {
      "type": "list",
      "description": "Output: distances"
    },
    "ids": {
      "type": "list",
      "description": "Output: ids"
    }
  },
  "dependencies": {
    "python": [],
    "system": []
  },
  "version": "1.0.0",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-02-11",
  "updated_at": "2026-03-03",
  "tags": [
    "vectorstore"
  ]
}
