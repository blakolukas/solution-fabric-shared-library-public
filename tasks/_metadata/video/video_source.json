{
  "id": "video_source",
  "category": "video",
  "display_name": "Video Source",
  "description": "Create a frame generator from a video file.",
  "inputs": {
    "video_path": {
      "type": "str",
      "required": true,
      "description": "Input parameter: video_path"
    },
    "target_fps": {
      "type": "Optional[float]",
      "required": false,
      "description": "Input parameter: target_fps",
      "default": null
    },
    "start_time": {
      "type": "float",
      "required": false,
      "description": "Input parameter: start_time",
      "default": 0.0
    },
    "end_time": {
      "type": "Optional[float]",
      "required": false,
      "description": "Input parameter: end_time",
      "default": null
    },
    "loop": {
      "type": "bool",
      "required": false,
      "description": "Input parameter: loop",
      "default": false
    }
  },
  "outputs": {
    "frame_generator": {
      "type": "generator",
      "description": "Output: frame_generator"
    },
    "metadata": {
      "type": "json",
      "description": "Output: metadata"
    }
  },
  "dependencies": {
    "python": [
      "opencv-python>=4.8.0"
    ],
    "system": []
  },
  "version": "1.0.0",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-02-11",
  "updated_at": "2026-03-03",
  "tags": [
    "video"
  ]
}
