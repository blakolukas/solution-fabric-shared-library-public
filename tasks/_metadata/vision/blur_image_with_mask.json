{
  "id": "blur_image_with_mask",
  "category": "vision",
  "display_name": "Blur Image with Mask",
  "description": "Apply Gaussian blur to an image based on a mask.",
  "inputs": {
    "image_array": {
      "type": "any",
      "required": true,
      "description": "Input parameter: image_array"
    },
    "mask_array": {
      "type": "any",
      "required": true,
      "description": "Input parameter: mask_array"
    },
    "blur_radius": {
      "type": "int",
      "required": false,
      "description": "Input parameter: blur_radius",
      "default": 15
    }
  },
  "outputs": {
    "blurred_image_array": {
      "type": "image",
      "description": "Output: blurred_image_array"
    }
  },
  "dependencies": {
    "python": [
      "numpy>=1.24.0",
      "opencv-python>=4.8.0"
    ],
    "system": []
  },
  "version": "1.0.0",
  "author": "FabricFlow Team",
  "contributors": [],
