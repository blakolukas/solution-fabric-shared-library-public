{
  "id": "chat_completion",
  "category": "llm",
  "display_name": "Chat Completion",
  "description": "Run chat completion using a messages list.",
  "inputs": {
    "model": {
      "type": "object",
      "required": true,
      "description": "Input parameter: model"
    },
    "messages": {
      "type": "list",
      "required": true,
      "description": "Input parameter: messages"
    },
    "max_tokens": {
      "type": "int",
      "required": false,
      "description": "Input parameter: max_tokens",
      "default": 256
    },
    "temperature": {
      "type": "float",
      "required": false,
      "description": "Input parameter: temperature",
      "default": 0.7
    }
  },
  "outputs": {
    "response": {
      "type": "text",
      "description": "Output: response"
    }
  },
  "dependencies": {
    "python": [],
    "system": []
  },
  "version": "1.0.0",
