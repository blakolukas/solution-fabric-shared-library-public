{
  "id": "llm_inference",
  "source_file": "llm_inference.py",
  "category": "llm",
  "display_name": "LLM Inference",
  "description": "Run inference on a loaded LLM model.",
  "is_collapsed": true,
  "inputs": {
    "model": {
      "type": "Any",
      "required": true,
      "description": "Input parameter: model"
    },
    "prompt": {
      "type": "str",
      "required": true,
      "description": "Input parameter: prompt"
    },
    "streaming": {
      "type": "bool",
      "required": false,
      "description": "Input parameter: streaming",
      "default": false
    },
    "max_tokens": {
      "type": "int",
      "required": false,
      "description": "Input parameter: max_tokens",
      "default": 256
    },
    "temperature": {
      "type": "float",
      "required": false,
      "description": "Input parameter: temperature",
      "default": 0.7
    },
    "top_p": {
      "type": "float",
      "required": false,
      "description": "Input parameter: top_p",
      "default": 0.9
    },
    "repeat_penalty": {
      "type": "float",
      "required": false,
      "description": "Input parameter: repeat_penalty",
      "default": 1.1
    },
    "top_k": {
      "type": "int",
      "required": false,
      "description": "Input parameter: top_k",
      "default": 40
    }
  },
  "outputs": {
    "response": {
      "type": "text",
      "description": "Output: response"
    }
  },
