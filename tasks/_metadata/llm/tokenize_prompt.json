{
  "id": "tokenize_prompt",
  "category": "llm",
  "display_name": "Tokenize Prompt",
  "description": "Tokenize a text prompt for LLM input.",
  "inputs": {
    "prompt": {
      "type": "str",
      "required": true,
      "description": "Input parameter: prompt"
    },
    "tokenizer": {
      "type": "object",
      "required": true,
      "description": "Input parameter: tokenizer"
    },
    "max_length": {
      "type": "int",
      "required": false,
      "description": "Input parameter: max_length",
      "default": 2048
    },
    "padding": {
      "type": "str",
      "required": false,
      "description": "Input parameter: padding",
      "default": "max_length"
    },
    "truncation": {
      "type": "bool",
      "required": false,
      "description": "Input parameter: truncation",
      "default": true
    },
    "return_tensors": {
      "type": "str",
      "required": false,
      "description": "Input parameter: return_tensors",
      "default": "pt"
    }
  },
  "outputs": {
    "tokenized": {
      "type": "object",
      "description": "Output: tokenized"
    }
  },
  "dependencies": {
    "python": [],
    "system": []
  },
  "version": "1.0.0",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-02-11",
  "updated_at": "2026-03-03",
  "tags": [
    "llm"
  ]
}
