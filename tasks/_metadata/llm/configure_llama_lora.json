{
  "id": "configure_llama_lora",
  "category": "llm",
  "display_name": "Configure Llama Lora",
  "description": "Configure LoRA (Low-Rank Adaptation) for LLaMA 3 fine-tuning.",
  "inputs": {
    "r": {
      "type": "int",
      "required": false,
      "description": "Input parameter: r",
      "default": 16
    },
    "lora_alpha": {
      "type": "int",
      "required": false,
      "description": "Input parameter: lora_alpha",
      "default": 32
    },
    "lora_dropout": {
      "type": "float",
      "required": false,
      "description": "Input parameter: lora_dropout",
      "default": 0.05
    },
    "target_modules": {
      "type": "list",
      "required": false,
      "description": "Input parameter: target_modules",
      "default": null
    },
    "bias": {
      "type": "str",
      "required": false,
      "description": "Input parameter: bias",
      "default": "none"
    },
    "task_type": {
      "type": "str",
      "required": false,
      "description": "Input parameter: task_type",
      "default": "CAUSAL_LM"
    }
  },
  "outputs": {
    "lora_config": {
      "type": "any",
      "description": "Output: lora_config"
    }
  },
  "dependencies": {
    "python": [],
    "system": []
  },
