{
  "id": "load_llama_tokenizer",
  "source_file": "load_llama_tokenizer.py",
  "category": "llm",
  "display_name": "Load LLaMA Tokenizer",
  "description": "Load a LLaMA tokenizer from HuggingFace.",
  "is_collapsed": false,
  "previewable": false,
  "inputs": {
    "model_name": {
      "type": "str",
      "required": false,
      "description": "Input parameter: model_name",
      "default": "meta-llama/Meta-Llama-3-8B-Instruct"
    },
    "padding_side": {
      "type": "str",
      "required": false,
      "description": "Input parameter: padding_side",
      "default": "right"
    },
    "add_eos_token": {
      "type": "bool",
      "required": false,
      "description": "Input parameter: add_eos_token",
      "default": true
    },
    "add_bos_token": {
      "type": "bool",
      "required": false,
      "description": "Input parameter: add_bos_token",
      "default": true
    },
    "trust_remote_code": {
      "type": "bool",
      "required": false,
      "description": "Input parameter: trust_remote_code",
      "default": true
    }
  },
  "outputs": {
    "tokenizer": {
      "type": "object",
      "description": "Output: tokenizer"
    }
  },
  "dependencies": {
    "python": [
      "transformers>=4.30.0"
    ],
    "system": []
