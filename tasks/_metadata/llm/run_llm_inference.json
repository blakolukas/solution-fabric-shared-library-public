{
  "id": "run_llm_inference",
  "category": "llm",
  "display_name": "Run LLM Inference",
  "description": "Run inference on a HuggingFace LLM model with tokenized input.",
  "is_collapsed": false,
  "inputs": {
    "tokenized": {
      "type": "dict",
      "required": true,
      "description": "Input parameter: tokenized"
    },
    "model": {
      "type": "object",
      "required": true,
      "description": "Input parameter: model"
    },
    "tokenizer": {
      "type": "object",
      "required": true,
      "description": "Input parameter: tokenizer"
    },
    "max_new_tokens": {
      "type": "int",
      "required": false,
      "description": "Input parameter: max_new_tokens",
      "default": 50
    },
    "min_new_tokens": {
      "type": "int",
      "required": false,
      "description": "Input parameter: min_new_tokens",
      "default": 10
    },
    "temperature": {
      "type": "float",
      "required": false,
      "description": "Input parameter: temperature",
      "default": 0.3
    },
    "top_p": {
      "type": "float",
      "required": false,
      "description": "Input parameter: top_p",
      "default": 0.9
    },
    "do_sample": {
      "type": "bool",
      "required": false,
      "description": "Input parameter: do_sample",
      "default": true
    }
  },
  "outputs": {
    "generated_ids": {
      "type": "object",
      "description": "Output: generated_ids"
    }
  },
  "dependencies": {
    "python": [
      "torch>=2.0.0"
    ],
    "system": []
  },
  "version": "1.0.0",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-02-11",
  "updated_at": "2026-03-06",
  "tags": [
    "llm"
  ]
}
