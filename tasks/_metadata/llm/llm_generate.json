{
  "id": "llm_generate",
  "category": "llm",
  "display_name": "LLM Generate",
  "description": "Generate text with token usage tracking.",
  "is_collapsed": true,
  "inputs": {
    "model": {
      "type": "object",
      "required": true,
      "description": "Input parameter: model"
    },
    "prompt": {
      "type": "str",
      "required": true,
      "description": "Input parameter: prompt"
    },
    "max_tokens": {
      "type": "int",
      "required": false,
      "description": "Input parameter: max_tokens",
      "default": 256
    },
    "temperature": {
      "type": "float",
      "required": false,
      "description": "Input parameter: temperature",
      "default": 0.7
    },
    "top_p": {
      "type": "float",
      "required": false,
      "description": "Input parameter: top_p",
      "default": 0.9
    },
    "stop": {
      "type": "Optional[list]",
      "required": false,
      "description": "Input parameter: stop",
      "default": null
    }
  },
  "outputs": {
    "response": {
      "type": "text",
      "description": "Output: response"
    },
    "tokens_used": {
      "type": "int",
      "description": "Output: tokens_used"
    }
  },
  "dependencies": {
    "python": [],
    "system": []
  },
  "version": "1.0.0",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-02-11",
  "updated_at": "2026-03-06",
  "tags": [
    "llm"
  ]
}
