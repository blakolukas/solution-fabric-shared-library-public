{
  "id": "configure_llama_training_arguments",
  "source_file": "configure_llama_training_arguments.py",
  "category": "llm",
  "display_name": "Configure Llama Training Arguments",
  "description": "Configure training arguments for LLaMA 3 fine-tuning.",
  "is_collapsed": false,
  "inputs": {
    "output_dir": {
      "type": "str",
      "required": false,
      "description": "Input parameter: output_dir",
      "default": "./llama_finetuned"
    },
    "num_train_epochs": {
      "type": "int",
      "required": false,
      "description": "Input parameter: num_train_epochs",
      "default": 3
    },
    "per_device_train_batch_size": {
      "type": "int",
      "required": false,
      "description": "Input parameter: per_device_train_batch_size",
      "default": 2
    },
    "per_device_eval_batch_size": {
      "type": "int",
      "required": false,
      "description": "Input parameter: per_device_eval_batch_size",
      "default": 2
    },
    "gradient_accumulation_steps": {
      "type": "int",
      "required": false,
      "description": "Input parameter: gradient_accumulation_steps",
      "default": 8
    },
    "learning_rate": {
      "type": "float",
      "required": false,
      "description": "Input parameter: learning_rate",
      "default": 0.0002
    },
    "weight_decay": {
      "type": "float",
      "required": false,
      "description": "Input parameter: weight_decay",
      "default": 0.01
    },
    "warmup_ratio": {
      "type": "float",
      "required": false,
      "description": "Input parameter: warmup_ratio",
      "default": 0.03
    },
    "lr_scheduler_type": {
      "type": "str",
      "required": false,
      "description": "Input parameter: lr_scheduler_type",
      "default": "cosine"
    },
    "logging_steps": {
      "type": "int",
      "required": false,
      "description": "Input parameter: logging_steps",
      "default": 10
    },
    "save_steps": {
      "type": "int",
      "required": false,
      "description": "Input parameter: save_steps",
      "default": 500
    },
    "save_total_limit": {
      "type": "int",
      "required": false,
      "description": "Input parameter: save_total_limit",
      "default": 2
    },
    "fp16": {
      "type": "bool",
      "required": false,
      "description": "Input parameter: fp16",
      "default": false
    },
    "bf16": {
      "type": "bool",
      "required": false,
      "description": "Input parameter: bf16",
      "default": true
    },
    "gradient_checkpointing": {
      "type": "bool",
      "required": false,
      "description": "Input parameter: gradient_checkpointing",
      "default": true
    },
    "optim": {
      "type": "str",
      "required": false,
      "description": "Input parameter: optim",
      "default": "paged_adamw_32bit"
    },
    "max_grad_norm": {
      "type": "float",
      "required": false,
      "description": "Input parameter: max_grad_norm",
      "default": 0.3
    },
    "group_by_length": {
      "type": "bool",
      "required": false,
      "description": "Input parameter: group_by_length",
      "default": true
    },
    "report_to": {
      "type": "str",
      "required": false,
      "description": "Input parameter: report_to",
      "default": "none"
    },
    "remove_unused_columns": {
      "type": "bool",
      "required": false,
      "description": "Input parameter: remove_unused_columns",
      "default": false
    }
  },
  "outputs": {
    "training_args": {
      "type": "any",
      "description": "Output: training_args"
    }
  },
  "dependencies": {
    "python": [
      "transformers>=4.30.0"
    ],
    "system": []
  },
  "version": "1.0.0",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-02-11",
  "updated_at": "2026-03-11",
  "tags": [
    "llm"
  ]
}
