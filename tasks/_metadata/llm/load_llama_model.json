{
  "id": "load_llama_model",
  "source_file": "load_llama_model.py",
  "category": "llm",
  "display_name": "Load LLaMA Model",
  "description": "Load a LLaMA model from HuggingFace with optional quantization.",
  "is_collapsed": false,
  "inputs": {
    "model_name": {
      "type": "str",
      "required": false,
      "description": "Input parameter: model_name",
      "default": "meta-llama/Meta-Llama-3-8B-Instruct"
    },
    "device_map": {
      "type": "str",
      "required": false,
      "description": "Input parameter: device_map",
      "default": "auto"
    },
    "torch_dtype": {
      "type": "str",
      "required": false,
      "description": "Input parameter: torch_dtype",
      "default": "bfloat16"
    },
    "load_in_8bit": {
      "type": "bool",
      "required": false,
      "description": "Input parameter: load_in_8bit",
      "default": false
    },
    "load_in_4bit": {
      "type": "bool",
      "required": false,
      "description": "Input parameter: load_in_4bit",
      "default": false
    },
    "attn_implementation": {
      "type": "Optional[str]",
      "required": false,
      "description": "Input parameter: attn_implementation",
      "default": null
    },
    "trust_remote_code": {
      "type": "bool",
      "required": false,
      "description": "Input parameter: trust_remote_code",
      "default": true
    }
  },
  "outputs": {
    "model": {
      "type": "object",
      "description": "Output: model"
    }
  },
  "dependencies": {
    "python": [
      "torch>=2.0.0",
      "transformers>=4.30.0"
    ],
    "system": []
  },
  "version": "1.0.0",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-02-11",
  "updated_at": "2026-03-11",
  "tags": [
    "llm"
  ]
}
