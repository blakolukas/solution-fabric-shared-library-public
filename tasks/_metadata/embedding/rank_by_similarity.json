{
  "id": "rank_by_similarity",
  "category": "embedding",
  "display_name": "Rank By Similarity",
  "description": "Rank embeddings by similarity to a query embedding.",
  "inputs": {
    "query_embedding": {
      "type": "list",
      "required": true,
      "description": "Input parameter: query_embedding"
    },
    "embeddings": {
      "type": "List[list]",
      "required": true,
      "description": "Input parameter: embeddings"
    },
    "top_k": {
      "type": "int",
      "required": false,
      "description": "Input parameter: top_k",
      "default": 5
    }
  },
  "outputs": {
    "scores": {
      "type": "list",
      "description": "Output: scores"
    },
    "indices": {
      "type": "list",
      "description": "Output: indices"
    }
  },
  "dependencies": {
    "python": [
      "numpy>=1.24.0"
    ],
    "system": []
  },
  "version": "1.0.0",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-02-11",
  "updated_at": "2026-02-19",
  "tags": [
    "embedding"
  ]
}
