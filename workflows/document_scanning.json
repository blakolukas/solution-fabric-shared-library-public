{
  "tasks": [
    {
      "name": "validate_document_path",
      "task": "check_file_exists",
      "displayName": "Check File Exists",
      "inputs": {
        "file_path": "inputs.document_image_path"
      },
      "outputs": [
        "file_path"
      ]
    },
    {
      "name": "load_image",
      "task": "load_image",
      "displayName": "Load Image",
      "inputs": {
        "image_path": "tasks.validate_document_path.file_path"
      },
      "outputs": [
        "image"
      ],
      "dependencies": [
        "validate_document_path"
      ]
    },
    {
      "name": "to_grayscale",
      "task": "convert_to_grayscale",
      "displayName": "Convert to Grayscale",
      "inputs": {
        "image": "tasks.load_image.image"
      },
      "outputs": [
        "grayscale_image"
      ],
      "dependencies": [
        "load_image"
      ]
    },
    {
      "name": "extract_text",
      "task": "extract_text_with_ocr",
      "displayName": "Extract Text With Ocr",
      "inputs": {
        "grayscale_image": "tasks.to_grayscale.grayscale_image",
        "language": "inputs.ocr_language"
      },
      "outputs": [
        "extracted_text"
      ],
      "dependencies": [
        "to_grayscale"
      ]
    },
    {
      "name": "ensure_output_dir",
      "task": "ensure_directory_exists",
      "displayName": "Ensure Directory Exists",
      "inputs": {
        "directory_path": "inputs.output_directory"
      },
      "outputs": [
        "directory_path"
      ]
    },
    {
      "name": "save_extracted_text",
      "task": "save_text_to_file",
      "displayName": "Save Text to File",
      "inputs": {
        "text": "tasks.extract_text.extracted_text",
        "directory": "tasks.ensure_output_dir.directory_path",
        "filename": {
          "literal": "extracted_text.txt"
        }
      },
      "outputs": [
        "file_path"
      ],
      "dependencies": [
        "extract_text",
        "ensure_output_dir"
      ]
    },
    {
      "name": "extract_ocr_positions",
      "task": "extract_ocr_data",
      "displayName": "Extract Ocr Data",
      "inputs": {
        "grayscale_image": "tasks.to_grayscale.grayscale_image",
        "language": "inputs.ocr_language"
      },
      "outputs": [
        "ocr_data"
      ],
      "dependencies": [
        "to_grayscale"
      ]
    },
    {
      "name": "get_dimensions",
      "task": "get_image_dimensions",
      "displayName": "Get Image Dimensions",
      "inputs": {
        "image": "tasks.load_image.image"
      },
      "outputs": [
        "image_dimensions"
      ],
      "dependencies": [
        "load_image"
      ]
    },
    {
      "name": "convert_to_rgb",
      "task": "convert_bgr_to_rgb",
      "displayName": "BGR to RGB",
      "inputs": {
        "image": "tasks.load_image.image"
      },
      "outputs": [
        "rgb_image"
      ],
      "dependencies": [
        "load_image"
      ]
    },
    {
      "name": "generate_temp_name",
      "task": "generate_temp_filename",
      "displayName": "Generate Temp Filename",
      "inputs": {
        "prefix": {
          "literal": "doc_scan"
        },
        "extension": {
          "literal": "png"
        }
      },
      "outputs": [
        "temp_filename"
      ]
    },
    {
      "name": "ensure_temp_dir",
      "task": "ensure_directory_exists",
      "displayName": "Ensure Directory Exists",
      "inputs": {
        "directory_path": {
          "literal": "temp"
        }
      },
      "outputs": [
        "directory_path"
      ]
    },
    {
      "name": "save_image_temp",
      "task": "save_image_to_disk",
      "displayName": "Save Image to Disk",
      "inputs": {
        "image_array": "tasks.convert_to_rgb.rgb_image",
        "save_path": "tasks.ensure_temp_dir.directory_path",
        "save_name": "tasks.generate_temp_name.temp_filename"
      },
      "outputs": [
        "saved_image_path"
      ],
      "dependencies": [
        "convert_to_rgb",
        "ensure_temp_dir",
        "generate_temp_name"
      ]
    },
    {
      "name": "generate_pdf",
      "task": "create_searchable_pdf",
      "displayName": "Create Searchable PDF",
      "inputs": {
        "image_path": "tasks.save_image_temp.saved_image_path",
        "ocr_data": "tasks.extract_ocr_positions.ocr_data",
        "image_dimensions": "tasks.get_dimensions.image_dimensions",
        "output_directory": "tasks.ensure_output_dir.directory_path",
        "output_name": {
          "literal": "scanned_document.pdf"
        }
      },
      "outputs": [
        "pdf"
      ],
      "dependencies": [
        "save_image_temp",
        "extract_ocr_positions",
        "get_dimensions",
        "ensure_output_dir"
      ]
    },
    {
      "name": "cleanup",
      "task": "delete_file",
      "displayName": "Delete File",
      "inputs": {
        "file_path": "tasks.save_image_temp.saved_image_path"
      },
      "outputs": [
        "deleted"
      ],
      "dependencies": [
        "generate_pdf"
      ]
    },
    {
      "name": "download_llm",
      "task": "download_hf_model",
      "displayName": "Download Hf Model",
      "inputs": {
        "repository_id": "inputs.llm_repository",
        "model_name": "inputs.llm_model_name"
      },
      "outputs": [
        "model_path"
      ]
    },
    {
      "name": "load_gguf",
      "task": "load_gguf_model",
      "displayName": "Load LLM (GGUF)",
      "inputs": {
        "model_path": "tasks.download_llm.model_path",
        "n_ctx": 4096,
        "n_gpu_layers": -1
      },
      "outputs": [
        "model"
      ],
      "dependencies": [
        "download_llm"
      ]
    },
    {
      "name": "format_prompt",
      "task": "format_template",
      "displayName": "Format Template",
      "inputs": {
        "template": "inputs.summary_prompt_template",
        "text": "tasks.extract_text.extracted_text"
      },
      "outputs": [
        "result"
      ],
      "dependencies": [
        "extract_text"
      ]
    },
    {
      "name": "generate_summary",
      "task": "llm_inference",
      "displayName": "LLM Inference",
      "inputs": {
        "model": "tasks.load_gguf.model",
        "max_tokens": 100,
        "temperature": 0.3,
        "prompt": "tasks.format_prompt.result"
      },
      "outputs": [
        "response"
      ],
      "dependencies": [
        "load_gguf",
        "format_prompt"
      ]
    },
    {
      "name": "save_summary",
      "task": "save_text_to_file",
      "displayName": "Save Text to File",
      "inputs": {
        "text": "tasks.generate_summary.response",
        "directory": "tasks.ensure_output_dir.directory_path",
        "filename": {
          "literal": "summary.txt"
        }
      },
      "outputs": [
        "file_path"
      ],
      "dependencies": [
        "generate_summary",
        "ensure_output_dir"
      ]
    }
  ],
  "inputs": {
    "document_image_path": "samples/media/document_sample.jpg",
    "ocr_language": "eng",
    "output_directory": "output",
    "llm_repository": "TheBloke/TinyLlama-1.1B-Chat-v1.0-GGUF",
    "llm_model_name": "tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf",
    "summary_prompt_template": "Provide a brief, one-sentence summary of the main topic of this document:\n\n{text}\n\nBrief summary:"
  },
  "outputs": {
    "summary": "tasks.generate_summary.response",
    "summary_path": "tasks.save_summary.file_path",
    "extracted_text_path": "tasks.save_extracted_text.file_path",
    "pdf_path": "tasks.generate_pdf.pdf",
    "document_image": "tasks.convert_to_rgb.rgb_image"
  },
  "name": "Untitled Workflow",
