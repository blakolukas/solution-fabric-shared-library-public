{
  "tasks": [
    {
      "name": "hf_login",
      "task": "huggingface_login",
      "displayName": "Huggingface Login",
      "inputs": {
        "token": "inputs.huggingface_token"
      },
      "outputs": [
        "login_status"
      ]
    },
    {
      "name": "load_model",
      "task": "load_llama_model",
      "displayName": "Load LLaMA Model",
      "inputs": {
        "model_name": "inputs.model_name",
        "device_map": "inputs.device_map",
        "torch_dtype": "inputs.torch_dtype",
        "load_in_4bit": false
      },
      "outputs": [
        "model"
      ],
      "dependencies": [
        "hf_login"
      ]
    },
    {
      "name": "load_tokenizer",
      "task": "load_llama_tokenizer",
      "displayName": "Load LLaMA Tokenizer",
      "inputs": {
        "model_name": "inputs.model_name",
        "padding_side": "inputs.padding_side"
      },
      "outputs": [
        "tokenizer"
      ],
      "dependencies": [
        "hf_login"
      ]
    },
    {
      "name": "load_dataset",
      "task": "load_training_dataset",
      "displayName": "Load Training Dataset",
      "inputs": {
        "dataset_name": "inputs.dataset_name",
        "split": "inputs.dataset_split"
      },
      "outputs": [
        "dataset"
      ],
      "dependencies": [
        "hf_login"
      ]
    },
    {
      "name": "prepare_dataset",
      "task": "prepare_llama_dataset_for_training",
      "displayName": "Prepare Llama Dataset For Training",
      "inputs": {
        "dataset": "tasks.load_dataset.dataset",
        "tokenizer": "tasks.load_tokenizer.tokenizer",
        "max_length": 2048,
        "num_proc": 4
      },
      "outputs": [
        "processed_dataset"
      ],
      "dependencies": [
        "load_dataset",
        "load_tokenizer"
      ]
    },
    {
      "name": "configure_lora",
      "task": "configure_llama_lora",
      "displayName": "Configure Llama Lora",
      "inputs": {
        "r": 16,
        "lora_alpha": 32,
        "lora_dropout": 0.05
      },
      "outputs": [
        "lora_config"
      ]
    },
    {
      "name": "configure_training",
      "task": "configure_llama_training_arguments",
      "displayName": "Configure Llama Training Arguments",
      "inputs": {
        "output_dir": "inputs.output_dir",
        "num_train_epochs": 1,
        "per_device_train_batch_size": 2,
        "gradient_accumulation_steps": 8,
        "learning_rate": 0.0002,
        "warmup_ratio": 0.03,
        "lr_scheduler_type": "inputs.lr_scheduler_type",
        "logging_steps": 10,
        "save_steps": 100,
        "save_total_limit": 2,
        "bf16": true,
        "gradient_checkpointing": true,
        "optim": "inputs.optimizer",
        "group_by_length": true
      },
      "outputs": [
        "training_args"
      ]
    },
    {
      "name": "initialize_trainer",
      "task": "initialize_llama_trainer",
      "displayName": "Initialize Llama Trainer",
      "inputs": {
        "model": "tasks.load_model.model",
        "lora_config": "tasks.configure_lora.lora_config",
        "training_args": "tasks.configure_training.training_args",
        "processed_dataset": "tasks.prepare_dataset.processed_dataset",
        "tokenizer": "tasks.load_tokenizer.tokenizer"
      },
      "outputs": [
        "trainer"
      ],
      "dependencies": [
        "load_model",
        "configure_lora",
        "configure_training",
        "prepare_dataset",
        "load_tokenizer"
      ]
    },
    {
      "name": "execute_training",
      "task": "execute_training",
      "displayName": "Execute Training",
      "inputs": {
        "trainer": "tasks.initialize_trainer.trainer"
      },
      "outputs": [
        "training_result",
        "trained_model"
      ],
      "dependencies": [
        "initialize_trainer"
      ]
    },
    {
      "name": "save_model",
      "task": "save_llama_model",
      "displayName": "Save Llama Model",
      "inputs": {
        "trained_model": "tasks.execute_training.trained_model",
        "tokenizer": "tasks.load_tokenizer.tokenizer",
        "output_dir": "inputs.final_output_dir"
      },
      "outputs": [
        "saved_model_path"
      ],
      "dependencies": [
        "execute_training",
        "load_tokenizer"
      ]
    }
  ],
  "inputs": {
    "huggingface_token": "",
    "model_name": "meta-llama/Meta-Llama-3-8B-Instruct",
    "device_map": "auto",
    "torch_dtype": "bfloat16",
    "padding_side": "right",
    "dataset_name": "HuggingFaceH4/ultrachat_200k",
    "dataset_split": "train_sft[:1000]",
    "output_dir": "./llama_finetuned",
    "lr_scheduler_type": "cosine",
    "optimizer": "paged_adamw_32bit",
    "final_output_dir": "./llama_finetuned_final"
  },
  "outputs": {
    "saved_model_path": "tasks.save_model.saved_model_path",
    "training_result": "tasks.execute_training.training_result"
  },
  "name": "Untitled Workflow",
