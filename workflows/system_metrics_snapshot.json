{
  "tasks": [
    {
      "name": "cpu",
      "task": "get_cpu_usage",
      "displayName": "Get CPU Usage",
      "outputs": [
        "cpu_percent",
        "core_count",
        "frequency_mhz"
      ]
    },
    {
      "name": "memory",
      "task": "get_memory_usage",
      "displayName": "Get Memory Usage",
      "outputs": [
        "memory_percent",
        "memory_used_gb",
        "memory_total_gb",
        "memory_available_gb"
      ]
    },
    {
      "name": "disk",
      "task": "get_disk_usage",
      "displayName": "Get Disk Usage",
      "inputs": {
        "path": "inputs.disk_path"
      },
      "outputs": [
        "disk_percent",
        "disk_used_gb",
        "disk_total_gb",
        "disk_free_gb"
      ]
    },
    {
      "name": "gpu",
      "task": "get_gpu_usage",
      "displayName": "Get GPU Usage",
      "outputs": [
        "gpu_name",
        "gpu_count",
        "gpu_memory_total_mb",
        "gpu_memory_used_mb",
        "gpu_memory_percent",
        "gpu_utilization_percent",
        "gpu_temperature_c"
      ]
    },
    {
      "name": "ts",
      "task": "get_current_timestamp",
      "displayName": "Get Current Timestamp",
      "outputs": [
        "timestamp"
      ]
    },
    {
      "name": "build_json",
      "task": "format_template",
      "displayName": "Build JSON",
      "inputs": {
        "template": {
          "literal": "{\"timestamp\": \"{timestamp}\", \"cpu\": {\"percent\": {cpu_percent}, \"core_count\": {core_count}, \"frequency_mhz\": {frequency_mhz}}, \"memory\": {\"percent\": {memory_percent}, \"used_gb\": {memory_used_gb}, \"total_gb\": {memory_total_gb}, \"available_gb\": {memory_available_gb}}, \"disk\": {\"path\": \"{disk_path}\", \"percent\": {disk_percent}, \"used_gb\": {disk_used_gb}, \"total_gb\": {disk_total_gb}, \"free_gb\": {disk_free_gb}}, \"gpu\": {\"name\": \"{gpu_name}\", \"count\": {gpu_count}, \"memory_total_mb\": {gpu_memory_total_mb}, \"memory_used_mb\": {gpu_memory_used_mb}, \"memory_percent\": {gpu_memory_percent}, \"utilization_percent\": {gpu_utilization_percent}, \"temperature_c\": {gpu_temperature_c}}}"
        },
        "timestamp": "tasks.ts.timestamp",
        "cpu_percent": "tasks.cpu.cpu_percent",
        "core_count": "tasks.cpu.core_count",
        "frequency_mhz": "tasks.cpu.frequency_mhz",
        "memory_percent": "tasks.memory.memory_percent",
        "memory_used_gb": "tasks.memory.memory_used_gb",
        "memory_total_gb": "tasks.memory.memory_total_gb",
        "memory_available_gb": "tasks.memory.memory_available_gb",
        "disk_path": "inputs.disk_path",
        "disk_percent": "tasks.disk.disk_percent",
        "disk_used_gb": "tasks.disk.disk_used_gb",
        "disk_total_gb": "tasks.disk.disk_total_gb",
        "disk_free_gb": "tasks.disk.disk_free_gb",
        "gpu_name": "tasks.gpu.gpu_name",
        "gpu_count": "tasks.gpu.gpu_count",
        "gpu_memory_total_mb": "tasks.gpu.gpu_memory_total_mb",
        "gpu_memory_used_mb": "tasks.gpu.gpu_memory_used_mb",
        "gpu_memory_percent": "tasks.gpu.gpu_memory_percent",
        "gpu_utilization_percent": "tasks.gpu.gpu_utilization_percent",
        "gpu_temperature_c": "tasks.gpu.gpu_temperature_c"
      },
      "outputs": [
        "result"
      ],
      "dependencies": [
        "cpu",
        "memory",
        "disk",
        "gpu",
        "ts"
      ]
    },
    {
      "name": "parse",
      "task": "parse_json",
      "displayName": "Parse JSON",
      "inputs": {
        "json_string": "tasks.build_json.result"
      },
      "outputs": [
        "data"
      ],
      "dependencies": [
        "build_json"
      ]
    }
  ],
  "inputs": {
    "disk_path": "/"
  },
  "outputs": {
    "metrics": "tasks.parse.data"
  },
  "name": "System Metrics Snapshot",
  "_internal": true,
  "_designer": {
    "layout": {
      "cpu": {
        "x": 100,
        "y": 50
      },
      "memory": {
        "x": 100,
        "y": 220
      },
      "disk": {
        "x": 100,
        "y": 390
      },
      "gpu": {
        "x": 100,
        "y": 560
      },
      "ts": {
        "x": 100,
        "y": 730
      },
      "build_json": {
        "x": 460,
        "y": 390
      },
      "parse": {
        "x": 820,
        "y": 390
      }
    },
    "taskDisplayNames": {
      "cpu": "Get CPU Usage",
      "memory": "Get Memory Usage",
      "disk": "Get Disk Usage",
      "gpu": "Get GPU Usage",
      "ts": "Get Current Timestamp",
      "build_json": "Build JSON",
      "parse": "Parse JSON"
    }
  }
}