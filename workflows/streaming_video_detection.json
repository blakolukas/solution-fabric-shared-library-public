{
  "tasks": [
    {
      "name": "validate_video_path",
      "task": "check_file_exists",
      "displayName": "Check File Exists",
      "inputs": {
        "file_path": "inputs.video_path"
      },
      "outputs": [
        "file_path"
      ]
    },
    {
      "name": "load_yolo",
      "task": "load_yolo_model",
      "displayName": "Load YOLO Model",
      "inputs": {
        "model_path": {
          "literal": "yolo11n.pt"
        }
      },
      "outputs": [
        "yolo_model"
      ]
    },
    {
      "name": "video_source",
      "task": "video_source",
      "displayName": "Video Source",
      "inputs": {
        "video_path": "tasks.validate_video_path.file_path",
        "target_fps": "inputs.target_fps"
      },
      "outputs": [
        "frame_generator",
        "metadata"
      ],
      "dependencies": [
        "validate_video_path"
      ]
    },
    {
      "name": "yolo_detect_objects",
      "task": "yolo_detect_objects",
      "displayName": "Detect Objects (YOLO)",
      "inputs": {
        "image": "tasks.video_source.frame_generator",
        "yolo_model": "tasks.load_yolo.yolo_model",
        "confidence_threshold": "inputs.confidence_threshold"
      },
      "outputs": [
        "detections"
      ],
      "dependencies": [
        "load_yolo",
        "video_source"
      ]
    },
    {
      "name": "draw_detection_boxes",
      "task": "draw_detection_boxes",
      "displayName": "Draw Detection Boxes",
      "inputs": {
        "image": "tasks.video_source.frame_generator",
        "detections": "tasks.yolo_detect_objects.detections"
      },
      "outputs": [
        "annotated_image"
      ],
      "dependencies": [
        "yolo_detect_objects"
      ]
    }
  ],
  "inputs": {
    "video_path": "samples/media/video_stream_sample.mp4",
    "target_fps": 15,
    "confidence_threshold": 0.25
  },
  "outputs": {
    "annotated_image": "tasks.draw_detection_boxes.annotated_image",
    "metadata": "tasks.video_source.metadata",
    "draw_detection_boxes.annotated_image": "tasks.draw_detection_boxes.annotated_image"
  },
  "name": "Untitled Workflow",
  "_designer": {
    "layout": {
      "validate_video_path": {
        "x": 100,
        "y": 100
      },
      "load_yolo": {
        "x": 427,
        "y": 91
      },
      "video_source": {
        "x": 801,
        "y": 84
      },
      "yolo_detect_objects": {
        "x": 1283,
        "y": 80
      },
      "draw_detection_boxes": {
        "x": 299,
        "y": 346
      }
    },
    "taskDisplayNames": {
      "validate_video_path": "Check File Exists",
      "load_yolo": "Load YOLO Model",
      "video_source": "Video Source",
      "yolo_detect_objects": "Detect Objects (YOLO)",
      "draw_detection_boxes": "Draw Detection Boxes"
    }
  }
}