{
  "tasks": [
    {
      "name": "hf_login",
      "task": "huggingface_login",
      "displayName": "Huggingface Login",
      "inputs": {
        "token": {
          "literal": ""
        }
      },
      "outputs": [
        "login_status"
      ]
    },
    {
      "name": "load_tokenizer",
      "task": "load_llama_tokenizer",
      "displayName": "Load LLaMA Tokenizer",
      "inputs": {
        "model_name": "inputs.model_name"
      },
      "outputs": [
        "tokenizer"
      ],
      "dependencies": [
        "hf_login"
      ]
    },
    {
      "name": "load_model",
      "task": "load_llama_model",
      "displayName": "Load LLaMA Model",
      "inputs": {
        "model_name": "inputs.model_name",
        "device_map": {
          "literal": "auto"
        },
        "torch_dtype": {
          "literal": "bfloat16"
        },
        "load_in_4bit": true
      },
      "outputs": [
        "model"
      ],
      "dependencies": [
        "hf_login"
      ]
    },
    {
      "name": "tokenize",
      "task": "tokenize_prompt",
      "displayName": "Tokenize Prompt",
      "inputs": {
        "prompt": "inputs.prompt",
        "tokenizer": "tasks.load_tokenizer.tokenizer",
        "max_length": 512
      },
      "outputs": [
        "tokenized"
      ],
      "dependencies": [
        "load_tokenizer"
      ]
    },
    {
      "name": "inference",
      "task": "run_llm_inference",
      "displayName": "Run LLM Inference",
      "inputs": {
        "tokenized": "tasks.tokenize.tokenized",
        "model": "tasks.load_model.model",
        "tokenizer": "tasks.load_tokenizer.tokenizer",
        "max_new_tokens": 100,
        "temperature": 0.7
      },
      "outputs": [
        "generated_ids"
      ],
      "dependencies": [
        "tokenize",
        "load_model"
      ]
    },
    {
      "name": "decode",
      "task": "decode_llm_output",
      "displayName": "Decode Llm Output",
      "inputs": {
        "output_ids": "tasks.inference.generated_ids",
        "tokenizer": "tasks.load_tokenizer.tokenizer"
      },
      "outputs": [
        "decoded_text"
      ],
      "dependencies": [
        "inference"
      ]
    }
  ],
  "inputs": {
    "model_name": "meta-llama/Meta-Llama-3-8B-Instruct",
    "prompt": "What is the capital of France?"
  },
  "outputs": {
    "response": "tasks.decode.decoded_text"
  },
