{
  "tasks": [
    {
      "name": "validate_image_path",
      "task": "check_file_exists",
      "displayName": "Check File Exists",
      "inputs": {
        "file_path": "inputs.image_path"
      },
      "outputs": [
        "file_path"
      ]
    },
    {
      "name": "load_yolo_model",
      "task": "load_yolo_model",
      "displayName": "Load YOLO Model",
      "outputs": [
        "yolo_model"
      ]
    },
    {
      "name": "load_image",
      "task": "load_image",
      "displayName": "Load Image",
      "inputs": {
        "image_path": "tasks.validate_image_path.file_path"
      },
      "outputs": [
        "image"
      ],
      "dependencies": [
        "validate_image_path"
      ]
    },
    {
      "name": "yolo_detect_objects",
      "task": "yolo_detect_objects",
      "displayName": "Detect Objects (YOLO)",
      "inputs": {
        "yolo_model": "tasks.load_yolo_model.yolo_model",
        "confidence_threshold": "inputs.confidence_threshold",
        "image": "tasks.load_image.image"
      },
      "outputs": [
        "detections"
      ],
      "dependencies": [
        "load_yolo_model",
        "load_image"
      ]
    },
    {
      "name": "draw_detection_boxes",
      "task": "draw_detection_boxes",
      "displayName": "Draw Detection Boxes",
      "inputs": {
        "detections": "tasks.yolo_detect_objects.detections",
        "image": "tasks.load_image.image"
      },
      "outputs": [
        "annotated_image"
      ],
      "dependencies": [
        "yolo_detect_objects",
        "load_image"
      ]
    }
  ],
  "inputs": {
    "image_path": "samples/media/object_detection_sample.jpg",
    "confidence_threshold": 0.8
  },
  "outputs": {
    "detections": "tasks.yolo_detect_objects.detections",
    "annotated_image": "tasks.draw_detection_boxes.annotated_image"
  },
  "name": "Untitled Workflow",
  "_designer": {
    "layout": {
      "validate_image_path": {
        "x": 100,
        "y": 100
      },
      "load_yolo_model": {
        "x": 508,
        "y": 70
      },
      "load_image": {
        "x": 858,
        "y": 74
      },
      "yolo_detect_objects": {
        "x": 1144,
        "y": 100
      },
      "draw_detection_boxes": {
        "x": 291,
        "y": 334
      }
    },
    "taskDisplayNames": {
      "validate_image_path": "Check File Exists",
      "load_yolo_model": "Load YOLO Model",
      "load_image": "Load Image",
      "yolo_detect_objects": "Detect Objects (YOLO)",
      "draw_detection_boxes": "Draw Detection Boxes"
    }
  }
}