{
  "id": "grammar_helper",
  "version": "1.0.0",
  "display_name": "Grammar Helper",
  "description": "Workflow: Grammar Helper",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-02-11",
  "updated_at": "2026-02-12",
  "tags": [
    "computer-vision",
    "llm",
    "ml",
    "text-generation"
  ],
  "category": "llm",
  "required_tasks": [
    "build_chat_prompt",
    "download_hf_model",
    "format_template",
    "llm_inference",
    "load_gguf_model",
    "trim",
    "word_count"
  ],
  "dependencies": {
    "python": [
      "torch>=2.0.0",
      "transformers>=4.30.0"
    ],
    "models": []
  },
  "inputs": {
    "model_repository": {
      "type": "string",
      "required": false,
      "default": "TheBloke/Mistral-7B-Instruct-v0.2-GGUF",
      "description": "Workflow input: model repository"
    },
    "model_filename": {
      "type": "string",
      "required": false,
      "default": "mistral-7b-instruct-v0.2.Q4_K_M.gguf",
      "description": "Workflow input: model filename"
    },
    "context_size": {
      "type": "int",
      "required": false,
      "default": 4096,
      "description": "Workflow input: context size"
    },
    "thread_count": {
      "type": "int",
      "required": false,
      "default": 8,
      "description": "Workflow input: thread count"
    },
    "input_text": {
      "type": "string",
      "required": false,
      "default": "me and sarah was working on the project when suddenly the computer crash and we loosed all our work its very frustrating because we was almost finished the report that was suppose to be submited yesterday but we didnt have no backup so now we got to start over from scratch which is gonna take alot of time the manager he dont understand how much effort we already putted into this and between you and I i think there being unreasonable with the deadline everyone in team is stressing out and morale is pretty low we should of backed up the files more regular but hindsight is 20/20 right irregardless we need to focus on getting this done asap",
      "description": "Workflow input: input text"
    },
    "max_tokens": {
      "type": "int",
      "required": false,
      "default": 512,
      "description": "Workflow input: max tokens"
    },
    "temperature": {
      "type": "float",
      "required": false,
      "default": 0.1,
      "description": "Workflow input: temperature"
    },
    "correction_style": {
      "type": "string",
      "required": false,
      "default": "professional",
      "description": "Workflow input: correction style"
    }
  },
  "outputs": {
    "summary_report": {
      "type": "any",
      "description": "Workflow output: summary report"
    },
    "original_text": {
      "type": "any",
      "description": "Workflow output: original text"
    },
    "corrected_text": {
      "type": "any",
      "description": "Workflow output: corrected text"
    },
    "styled_text": {
      "type": "any",
      "description": "Workflow output: styled text"
    },
    "changes_explained": {
      "type": "any",
      "description": "Workflow output: changes explained"
    },
    "word_count_original": {
      "type": "any",
      "description": "Workflow output: word count original"
    },
    "word_count_corrected": {
      "type": "any",
      "description": "Workflow output: word count corrected"
    },
    "word_count_styled": {
      "type": "any",
      "description": "Workflow output: word count styled"
    }
  }
}
