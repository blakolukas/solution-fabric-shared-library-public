{
  "id": "workflow_orchestrate",
  "version": "1.0.0",
  "display_name": "Workflow Orchestrate",
  "description": "Runs any workflow on a FabricFlow agent, using an existing instance or creating a new one.",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-03-19",
  "updated_at": "2026-03-19",
  "tags": [
    "workflow",
    "orchestration",
    "automation"
  ],
  "category": "workflow",
  "required_tasks": [
    "run_workflow"
  ],
  "dependencies": {
    "python": [],
    "models": []
  },
  "inputs": {
    "workflow_name": {
      "type": "string",
      "required": false,
      "default": "",
      "description": "Workflow input: workflow name"
    },
    "agent_id": {
      "type": "string",
      "required": false,
      "default": "http://127.0.0.1:8000",
      "description": "Workflow input: agent id"
    },
    "params": {
      "type": "object",
      "required": false,
      "default": {},
      "description": "Workflow input: params"
    },
    "use_existing_instance": {
      "type": "bool",
      "required": false,
      "default": false,
      "description": "Workflow input: use existing instance"
    },
    "instance_guid": {
      "type": "string",
      "required": false,
      "default": null,
      "description": "Workflow input: instance guid"
    },
    "execution_mode": {
      "type": "string",
      "required": false,
      "default": "sync",
      "description": "Workflow input: execution mode"
    },
    "ttl_seconds": {
      "type": "int",
      "required": false,
      "default": 3600,
      "description": "Workflow input: ttl seconds"
    },
    "session_guid": {
      "type": "string",
      "required": false,
      "default": null,
      "description": "Workflow input: session guid"
    }
  },
  "outputs": {
    "execution_id": {
      "type": "str",
      "description": "Workflow output: execution id",
      "previewable": true,
      "is_collapsed": true
    },
    "status": {
      "type": "str",
      "description": "Workflow output: exists | not_exists | failed",
      "previewable": true,
      "is_collapsed": false
    },
    "outputs": {
      "type": "object",
      "description": "Workflow output: outputs returned by the executed workflow",
      "previewable": true,
      "is_collapsed": true
    },
    "instance_guid": {
      "type": "str",
      "description": "Workflow output: instance guid",
      "previewable": true,
      "is_collapsed": true
    }
  }
}
