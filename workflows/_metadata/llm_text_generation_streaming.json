{
  "id": "llm_text_generation_streaming",
  "version": "1.0.0",
  "display_name": "Llm Text Generation Streaming",
  "description": "Streams LLM inference responses token-by-token. Internal workflow used by Compute Fabric for the chat feature.",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-03-05",
  "updated_at": "2026-03-16",
  "tags": [
    "llm",
    "streaming",
    "text-generation",
    "internal"
  ],
  "category": "internal",
  "required_tasks": [
    "build_chat_prompt",
    "download_hf_model",
    "llm_inference",
    "load_gguf_model"
  ],
  "dependencies": {
    "python": [
      "torch>=2.0.0",
      "transformers>=4.30.0"
    ],
    "models": []
  },
  "inputs": {
    "model_repository": {
      "type": "string",
      "required": false,
      "default": "TheBloke/Mistral-7B-Instruct-v0.2-GGUF",
      "description": "Workflow input: model repository"
    },
    "model_filename": {
      "type": "string",
      "required": false,
      "default": "mistral-7b-instruct-v0.2.Q4_K_M.gguf",
      "description": "Workflow input: model filename"
    },
    "context_size": {
      "type": "int",
      "required": false,
      "default": 4096,
      "description": "Workflow input: context size"
    },
    "system_message": {
      "type": "string",
      "required": false,
      "default": "You are a helpful assistant.",
      "description": "Workflow input: system message"
    },
    "user_message": {
      "type": "string",
      "required": false,
      "default": "What is Python 3? and what is consciousness?",
      "description": "Workflow input: user message"
    },
    "format_style": {
      "type": "string",
      "required": false,
      "default": "chatml",
      "description": "Workflow input: format style"
    },
    "max_tokens": {
      "type": "int",
      "required": false,
      "default": 512,
      "description": "Workflow input: max tokens"
    },
    "temperature": {
      "type": "float",
      "required": false,
      "default": 0.7,
      "description": "Workflow input: temperature"
    }
  },
  "outputs": {
    "response": {
      "type": "any",
      "description": "Workflow output: response"
    }
  },
  "internal": true
}
