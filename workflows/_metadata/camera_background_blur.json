{
  "id": "camera_background_blur",
  "version": "1.0.0",
  "display_name": "Camera Background Blur",
  "description": "Workflow: Camera Background Blur",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-02-11",
  "updated_at": "2026-03-06",
  "tags": [
    "computer-vision",
    "ml",
    "segmentation",
    "video-processing",
    "vision"
  ],
  "category": "vision",
  "required_tasks": [
    "batch_array",
    "blur_image_with_mask",
    "check_file_exists",
    "convert_array_dtype",
    "convert_channel_format",
    "download_hf_model",
    "ensure_array_contiguous",
    "extract_array_hw",
    "extract_first_element",
    "extract_hw_from_shape",
    "extract_onnx_model",
    "load_image",
    "min_max_normalize_image",
    "onnx_get_input_info",
    "onnx_inference",
    "onnx_load_model",
    "process_segmentation_mask",
    "resize_image",
    "unbatch_array",
    "visualize_segmentation_mask"
  ],
  "dependencies": {
    "python": [
      "numpy>=1.24.0",
      "onnxruntime>=1.15.0",
      "opencv-python>=4.8.0",
      "torch>=2.0.0",
      "transformers>=4.30.0"
    ],
    "models": []
  },
  "inputs": {
    "image_path": {
      "type": "string",
      "required": false,
      "default": "samples/media/object_detection_sample.jpg",
      "description": "Workflow input: image path"
    },
    "model_repository": {
      "type": "string",
      "required": false,
      "default": "qualcomm/FCN-ResNet50",
      "description": "Workflow input: model repository"
    },
    "model_name": {
      "type": "string",
      "required": false,
      "default": "FCN-ResNet50_float.onnx.zip",
      "description": "Workflow input: model name"
    },
    "model_revision": {
      "type": "string",
      "required": false,
      "default": "v0.45.0",
      "description": "Workflow input: model revision"
    },
    "base_directory": {
      "type": "string",
      "required": false,
      "default": "models",
      "description": "Workflow input: base directory"
    },
    "keep_class_id": {
      "type": "int",
      "required": false,
      "default": 12,
      "description": "Workflow input: keep class id"
    },
    "blur_radius": {
      "type": "int",
      "required": false,
      "default": 90,
      "description": "Workflow input: blur radius"
    }
  },
  "outputs": {
    "blurred_image": {
      "type": "any",
      "description": "Workflow output: blurred image"
    }
  }
}