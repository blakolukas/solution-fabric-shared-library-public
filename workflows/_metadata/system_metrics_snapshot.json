    "get_cpu_usage",
    "get_current_timestamp",
    "get_disk_usage",
    "get_memory_usage",
    "parse_json"
  ],
  "dependencies": {
    "python": [],
    "models": []
  },
  "inputs": {
    "disk_path": {
      "type": "string",
      "required": false,
      "default": "/",
      "description": "Workflow input: disk path"
