{
  "id": "system_metrics_snapshot",
  "version": "1.1.0",
  "display_name": "System Metrics Snapshot",
  "description": "Collects a live snapshot of CPU, memory, disk, and GPU usage from the host machine and returns the metrics as structured JSON. Internal workflow used by Compute Fabric for resource monitoring.",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-03-12",
  "updated_at": "2026-03-16",
  "tags": [
    "system",
    "metrics",
    "monitoring",
    "internal"
  ],
  "category": "internal",
  "required_tasks": [
    "format_template",
    "get_cpu_usage",
    "get_current_timestamp",
    "get_disk_usage",
    "get_gpu_usage",
    "get_memory_usage",
    "parse_json"
  ],
  "dependencies": {
    "python": [],
    "models": []
  },
  "inputs": {
    "disk_path": {
      "type": "string",
      "required": false,
      "default": "/",
      "description": "Workflow input: disk path"
    }
  },
  "outputs": {
    "metrics": {
      "type": "any",
      "description": "Workflow output: metrics"
    }
  },
  "internal": true,
  "auto_schedule": {
    "cron": "@every 5s",
    "overlap_policy": "skip",
    "on_error": "continue"
  }
}
