{
  "id": "llama_finetuning",
  "version": "1.0.0",
  "display_name": "Llama Finetuning",
  "description": "Workflow: Llama Finetuning",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-02-11",
  "updated_at": "2026-03-03",
  "tags": [
    "computer-vision",
    "llm",
    "ml",
    "text-generation"
  ],
  "category": "llm",
  "required_tasks": [
    "configure_llama_lora",
    "configure_llama_training_arguments",
    "execute_training",
    "huggingface_login",
    "initialize_llama_trainer",
    "load_llama_model",
    "load_llama_tokenizer",
    "load_training_dataset",
    "prepare_llama_dataset_for_training",
    "save_llama_model"
  ],
  "dependencies": {
    "python": [
      "torch>=2.0.0",
      "transformers>=4.30.0"
    ],
    "models": []
  },
  "inputs": {
    "huggingface_token": {
      "type": "string",
      "required": false,
      "default": "",
      "description": "Workflow input: huggingface token"
    },
    "model_name": {
      "type": "string",
      "required": false,
      "default": "meta-llama/Meta-Llama-3-8B-Instruct",
      "description": "Workflow input: model name"
    },
    "device_map": {
      "type": "string",
      "required": false,
      "default": "auto",
      "description": "Workflow input: device map"
    },
    "torch_dtype": {
      "type": "string",
      "required": false,
      "default": "bfloat16",
      "description": "Workflow input: torch dtype"
    },
    "padding_side": {
      "type": "string",
      "required": false,
      "default": "right",
      "description": "Workflow input: padding side"
    },
    "dataset_name": {
      "type": "string",
      "required": false,
      "default": "HuggingFaceH4/ultrachat_200k",
      "description": "Workflow input: dataset name"
    },
    "dataset_split": {
      "type": "string",
      "required": false,
      "default": "train_sft[:1000]",
      "description": "Workflow input: dataset split"
    },
    "output_dir": {
      "type": "string",
      "required": false,
      "default": "./llama_finetuned",
      "description": "Workflow input: output dir"
    },
    "lr_scheduler_type": {
      "type": "string",
      "required": false,
      "default": "cosine",
      "description": "Workflow input: lr scheduler type"
    },
    "optimizer": {
      "type": "string",
      "required": false,
      "default": "paged_adamw_32bit",
      "description": "Workflow input: optimizer"
    },
    "final_output_dir": {
      "type": "string",
      "required": false,
      "default": "./llama_finetuned_final",
      "description": "Workflow input: final output dir"
    }
  },
  "outputs": {
    "saved_model_path": {
      "type": "any",
      "description": "Workflow output: saved model path"
    },
    "training_result": {
      "type": "any",
      "description": "Workflow output: training result"
    }
  }
}
