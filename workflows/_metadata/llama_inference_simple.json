{
  "id": "llama_inference_simple",
  "version": "1.0.0",
  "display_name": "Llama Inference Simple",
  "description": "Workflow: Llama Inference Simple",
  "author": "FabricFlow Team",
  "contributors": [],
  "created_at": "2026-02-11",
  "updated_at": "2026-03-17",
  "tags": [
    "computer-vision",
    "llm",
    "ml",
    "text-generation"
  ],
  "category": "llm",
  "required_tasks": [
    "decode_llm_output",
    "huggingface_login",
    "load_llama_model",
    "load_llama_tokenizer",
    "run_llm_inference",
    "tokenize_prompt"
  ],
  "dependencies": {
    "python": [
      "torch>=2.0.0",
      "transformers>=4.30.0"
    ],
    "models": []
  },
  "inputs": {
    "model_name": {
      "type": "string",
      "required": false,
      "default": "meta-llama/Meta-Llama-3-8B-Instruct",
      "description": "Workflow input: model name"
    },
    "prompt": {
      "type": "string",
      "required": false,
      "default": "What is the capital of France?",
      "description": "Workflow input: prompt"
    },
    "hf_token": {
      "type": "string",
      "required": false,
      "default": null,
      "description": "Workflow input: hf token"
    }
  },
  "outputs": {
    "response": {
      "type": "any",
      "description": "Workflow output: response"
    }
  }
}
