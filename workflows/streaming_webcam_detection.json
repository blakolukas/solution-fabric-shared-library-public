{
  "tasks": [
    {
      "name": "load_yolo",
      "task": "load_yolo_model",
      "displayName": "Load YOLO Model",
      "inputs": {
        "model_path": {
          "literal": "yolo11n.pt"
        }
      },
      "outputs": [
        "yolo_model"
      ]
    },
    {
      "name": "camera_source",
      "task": "camera_source",
      "displayName": "Camera Source",
      "inputs": {
        "camera_index": "inputs.camera_index",
        "target_fps": "inputs.target_fps"
      },
      "outputs": [
        "frame_generator",
        "metadata"
      ]
    },
    {
      "name": "yolo_detect_objects",
      "task": "yolo_detect_objects",
      "displayName": "Detect Objects (YOLO)",
      "inputs": {
        "image": "tasks.camera_source.frame_generator",
        "yolo_model": "tasks.load_yolo.yolo_model",
        "confidence_threshold": "inputs.confidence_threshold"
      },
      "outputs": [
        "detections"
      ],
      "dependencies": [
        "load_yolo",
        "camera_source"
      ]
    },
    {
      "name": "draw_detection_boxes",
      "task": "draw_detection_boxes",
      "displayName": "Draw Detection Boxes",
      "inputs": {
        "image": "tasks.camera_source.frame_generator",
        "detections": "tasks.yolo_detect_objects.detections"
      },
      "outputs": [
        "annotated_image"
      ],
      "dependencies": [
        "yolo_detect_objects"
      ]
    }
  ],
  "inputs": {
    "camera_index": 0,
    "target_fps": 15,
    "confidence_threshold": 0.25
  },
  "outputs": {
    "annotated_image": "tasks.draw_detection_boxes.annotated_image",
    "metadata": "tasks.camera_source.metadata",
    "draw_detection_boxes.annotated_image": "tasks.draw_detection_boxes.annotated_image"
  },
  "name": "Untitled Workflow",
  "_designer": {
    "layout": {
      "load_yolo": {
        "x": 26,
        "y": 92
      },
      "camera_source": {
        "x": 405,
        "y": 85
      },
      "yolo_detect_objects": {
        "x": 759,
        "y": 71
      },
      "draw_detection_boxes": {
        "x": 1168,
        "y": 108
      }
    },
    "taskDisplayNames": {
      "load_yolo": "Load YOLO Model",
      "camera_source": "Camera Source",
      "yolo_detect_objects": "Detect Objects (YOLO)",
      "draw_detection_boxes": "Draw Detection Boxes"
    }
  }
}