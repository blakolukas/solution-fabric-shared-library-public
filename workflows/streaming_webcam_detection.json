{
  "inputs": {
    "yolo_model_path": "yolo11n.pt",
    "camera_index": 0,
    "target_fps": 15,
    "confidence_threshold": 0.25
  },
  "tasks": [
    {
      "name": "load_yolo",
      "task": "load_yolo_model",
      "inputs": {
        "model_path": "inputs.yolo_model_path"
      },
      "outputs": [
        "yolo_model"
      ]
    },
    {
      "name": "camera_source",
      "task": "camera_source",
      "inputs": {
        "camera_index": "inputs.camera_index",
        "target_fps": "inputs.target_fps"
      },
      "outputs": [
        "frame_generator",
        "metadata"
      ]
    },
    {
      "name": "yolo_detect_objects",
      "task": "yolo_detect_objects",
      "inputs": {
        "image": "tasks.camera_source.frame_generator",
        "yolo_model": "tasks.load_yolo.yolo_model",
        "confidence_threshold": "inputs.confidence_threshold"
      },
      "outputs": [
        "detections"
      ],
      "dependencies": [
        "load_yolo",
        "camera_source"
      ]
    },
    {
      "name": "draw_detection_boxes",
      "task": "draw_detection_boxes",
      "inputs": {
        "image": "tasks.camera_source.frame_generator",
        "detections": "tasks.yolo_detect_objects.detections"
      },
      "outputs": [
        "annotated_image"
      ],
      "dependencies": [
        "yolo_detect_objects"
      ]
    }
  ],
  "inputs": {
    "yolo_model_path": "yolo11n.pt",
    "camera_index": 0,
    "target_fps": 15,
    "confidence_threshold": 0.25
  },
  "description": "Stream webcam frames through YOLO detection with direct task connections.",
  "outputs": {
    "annotated_image": "tasks.draw_detection_boxes.annotated_image",
    "metadata": "tasks.camera_source.metadata"
  },
  "_designer": {
    "layout": {
      "validate_model_path": {
        "x": -200,
        "y": 150
      },
      "load_yolo": {
        "x": 100,
        "y": 150
      },
      "camera_source": {
        "x": 113.85642737896495,
        "y": 370.11686143572626
      },
      "yolo_detect_objects": {
        "x": 550,
        "y": 300
      },
      "draw_detection_boxes": {
        "x": 914.8580968280468,
        "y": 635.559265442404
      }
    }
  }
}
