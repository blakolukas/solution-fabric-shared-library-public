{
  "tasks": [
    {
      "name": "download_model",
      "task": "download_hf_model",
      "displayName": "Download Hf Model",
      "inputs": {
        "repository_id": "inputs.model_repository",
        "model_name": "inputs.model_filename"
      },
      "outputs": [
        "model_path"
      ]
    },
    {
      "name": "load_llm",
      "task": "load_gguf_model",
      "displayName": "Load LLM (GGUF)",
      "inputs": {
        "model_path": "tasks.download_model.model_path",
        "n_ctx": "inputs.context_size",
        "n_gpu_layers": -1,
        "verbose": false
      },
      "outputs": [
        "model"
      ],
      "dependencies": [
        "download_model"
      ]
    },
    {
      "name": "build_prompt",
      "task": "build_chat_prompt",
      "displayName": "Build Chat Prompt",
      "inputs": {
        "system_message": "inputs.system_message",
        "user_message": "inputs.user_message",
        "format_style": "inputs.format_style"
      },
      "outputs": [
        "prompt"
      ]
    },
    {
      "name": "generate",
      "task": "llm_inference",
      "displayName": "LLM Inference",
      "inputs": {
        "model": "tasks.load_llm.model",
        "prompt": "tasks.build_prompt.prompt",
        "streaming": true,
        "max_tokens": "inputs.max_tokens",
        "temperature": "inputs.temperature",
        "top_p": 0.9,
        "repeat_penalty": 1.1,
        "top_k": 40
      },
      "outputs": [
        "response"
      ],
      "dependencies": [
        "load_llm",
        "build_prompt"
      ]
    }
  ],
  "inputs": {
    "model_repository": "TheBloke/Mistral-7B-Instruct-v0.2-GGUF",
    "model_filename": "mistral-7b-instruct-v0.2.Q4_K_M.gguf",
    "context_size": 4096,
    "system_message": "You are a helpful assistant.",
    "user_message": "What is Python 3? and what is consciousness?",
    "format_style": "chatml",
    "max_tokens": 512,
    "temperature": 0.7
  },
  "outputs": {
    "response": "tasks.generate.response"
  },
