{
  "tasks": [
    {
      "name": "ensure_dir",
      "task": "ensure_directory_exists",
      "displayName": "Ensure Directory Exists",
      "inputs": {
        "directory_path": "inputs.output_dir"
      },
      "outputs": [
        "directory_path"
      ]
    },
    {
      "name": "unique_filename",
      "task": "generate_temp_filename",
      "displayName": "Generate Temp Filename",
      "inputs": {
        "prefix": "inputs.report_label",
        "extension": {
          "literal": "md"
        }
      },
      "outputs": [
        "temp_filename"
      ]
    },
    {
      "name": "count_words",
      "task": "word_count",
      "displayName": "Word Count",
      "inputs": {
        "text": "inputs.content"
      },
      "outputs": [
        "word_count"
      ]
    },
    {
      "name": "count_chars",
      "task": "char_count",
      "displayName": "Character Count",
      "inputs": {
        "text": "inputs.content"
      },
      "outputs": [
        "char_count"
      ]
    },
    {
      "name": "build_report",
      "task": "format_template",
      "displayName": "Format Template",
      "inputs": {
        "template": {
          "literal": "# {label} Report\n\n**Content:**\n\n> {content}\n\n---\n\n| Metric | Value |\n|--------|-------|\n| Words  | {words} |\n| Chars  | {chars} |\n"
        },
        "label": "inputs.report_label",
        "content": "inputs.content",
        "words": "tasks.count_words.word_count",
        "chars": "tasks.count_chars.char_count"
      },
      "outputs": [
        "result"
      ],
      "dependencies": [
        "count_words",
        "count_chars"
      ]
    },
    {
      "name": "save_report",
      "task": "save_text_to_file",
      "displayName": "Save Text to File",
      "inputs": {
        "text": "tasks.build_report.result",
        "directory": "tasks.ensure_dir.directory_path",
        "filename": "tasks.unique_filename.temp_filename"
      },
      "outputs": [
        "file_path"
      ],
      "dependencies": [
        "ensure_dir",
        "unique_filename",
        "build_report"
      ]
    }
  ],
  "inputs": {
    "output_dir": "~/scheduler-reports",
    "report_label": "Heartbeat",
    "content": "FabricFlow scheduler is running correctly."
  },
  "outputs": {
    "report_file": "tasks.save_report.file_path"
  },
  "name": "Untitled Workflow",
  "_designer": {
    "layout": {
      "ensure_dir": {
        "x": 100,
        "y": 100
      },
      "unique_filename": {
        "x": 403,
        "y": 106
      },
      "count_words": {
        "x": 738,
        "y": 95
      },
      "count_chars": {
        "x": 961,
        "y": 96
      },
      "build_report": {
        "x": 79,
        "y": 376
      },
      "save_report": {
        "x": 404,
        "y": 356
      }
    },
    "taskDisplayNames": {
      "ensure_dir": "Ensure Directory Exists",
      "unique_filename": "Generate Temp Filename",
      "count_words": "Word Count",
      "count_chars": "Character Count",
      "build_report": "Format Template",
      "save_report": "Save Text to File"
    }
  }
}