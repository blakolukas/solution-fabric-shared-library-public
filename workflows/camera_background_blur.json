{
  "tasks": [
    {
      "name": "validate_image_path",
      "task": "check_file_exists",
      "displayName": "Check File Exists",
      "inputs": {
        "file_path": "inputs.image_path"
      },
      "outputs": [
        "file_path"
      ]
    },
    {
      "name": "load_image",
      "task": "load_image",
      "displayName": "Load Image",
      "inputs": {
        "image_path": "tasks.validate_image_path.file_path"
      },
      "outputs": [
        "image"
      ],
      "dependencies": [
        "validate_image_path"
      ]
    },
    {
      "name": "download_model",
      "task": "download_hf_model",
      "displayName": "Download Hf Model",
      "inputs": {
        "repository_id": "inputs.model_repository",
        "model_name": "inputs.model_name",
        "revision": "inputs.model_revision"
      },
      "outputs": [
        "model_path"
      ]
    },
    {
      "name": "extract_model",
      "task": "extract_onnx_model",
      "displayName": "Extract Onnx Model",
      "inputs": {
        "model_path": "tasks.download_model.model_path",
        "repository_id": "inputs.model_repository",
        "base_directory": "inputs.base_directory"
      },
      "outputs": [
        "onnx_model_path"
      ],
      "dependencies": [
        "download_model"
      ]
    },
    {
      "name": "load_model",
      "task": "onnx_load_model",
      "displayName": "Onnx Load Model",
      "inputs": {
        "onnx_model_path": "tasks.extract_model.onnx_model_path"
      },
      "outputs": [
        "onnx_session"
      ],
      "dependencies": [
        "extract_model"
      ]
    },
    {
      "name": "get_input_info",
      "task": "onnx_get_input_info",
      "displayName": "Onnx Get Input Info",
      "inputs": {
        "onnx_session": "tasks.load_model.onnx_session"
      },
      "outputs": [
        "input_name",
        "input_shape",
        "input_type"
      ],
      "dependencies": [
        "load_model"
      ]
    },
    {
      "name": "extract_hw",
      "task": "extract_hw_from_shape",
      "displayName": "Extract H/W from Shape",
      "inputs": {
        "input_shape": "tasks.get_input_info.input_shape"
      },
      "outputs": [
        "height",
        "width"
      ],
      "dependencies": [
        "get_input_info"
      ]
    },
    {
      "name": "extract_original_hw",
      "task": "extract_array_hw",
      "displayName": "Extract Array Height/Width",
      "inputs": {
        "array": "tasks.load_image.image"
      },
      "outputs": [
        "orig_height",
        "orig_width"
      ],
      "dependencies": [
        "load_image"
      ]
    },
    {
      "name": "resize_image",
      "task": "resize_image",
      "displayName": "Resize Image",
      "inputs": {
        "image": "tasks.load_image.image",
        "target_width": "tasks.extract_hw.width",
        "target_height": "tasks.extract_hw.height"
      },
      "outputs": [
        "resized_image"
      ],
      "dependencies": [
        "extract_hw",
        "load_image"
      ]
    },
    {
      "name": "to_float32",
      "task": "convert_array_dtype",
      "displayName": "Convert Array Data Type",
      "inputs": {
        "array": "tasks.resize_image.resized_image",
        "target_dtype": {
          "literal": "float32"
        }
      },
      "outputs": [
        "converted_array"
      ],
      "dependencies": [
        "resize_image"
      ]
    },
    {
      "name": "min_max_normalize_image",
      "task": "min_max_normalize_image",
      "displayName": "Min-Max Normalize Image",
      "inputs": {
        "image_array": "tasks.to_float32.converted_array",
        "min_value": 0,
        "max_value": 1
      },
      "outputs": [
        "normalized_image_array"
      ],
      "dependencies": [
        "to_float32"
      ]
    },
    {
      "name": "to_channel_first",
      "task": "convert_channel_format",
      "displayName": "Convert Channel Format",
      "inputs": {
        "array": "tasks.min_max_normalize_image.normalized_image_array",
        "to_format": {
          "literal": "channel_first"
        }
      },
      "outputs": [
        "converted_array"
      ],
      "dependencies": [
        "min_max_normalize_image"
      ]
    },
    {
      "name": "batch_image",
      "task": "batch_array",
      "displayName": "Batch Array",
      "inputs": {
        "array": "tasks.to_channel_first.converted_array"
      },
      "outputs": [
        "batched_array"
      ],
      "dependencies": [
        "to_channel_first"
      ]
    },
    {
      "name": "ensure_contiguous",
      "task": "ensure_array_contiguous",
      "displayName": "Ensure Array Contiguous",
      "inputs": {
        "array": "tasks.batch_image.batched_array"
      },
      "outputs": [
        "contiguous_array"
      ],
      "dependencies": [
        "batch_image"
      ]
    },
    {
      "name": "run_inference",
      "task": "onnx_inference",
      "displayName": "Onnx Inference",
      "inputs": {
        "onnx_session": "tasks.load_model.onnx_session",
        "input_array": "tasks.ensure_contiguous.contiguous_array",
        "input_name": "tasks.get_input_info.input_name"
      },
      "outputs": [
        "output"
      ],
      "dependencies": [
        "ensure_contiguous",
        "load_model",
        "get_input_info"
      ]
    },
    {
      "name": "extract_first_element",
      "task": "extract_first_element",
      "displayName": "Get First Element",
      "inputs": {
        "output_list": "tasks.run_inference.output"
      },
      "outputs": [
        "first_element"
      ],
      "dependencies": [
        "run_inference"
      ]
    },
    {
      "name": "unbatch_output",
      "task": "unbatch_array",
      "displayName": "Unbatch Array",
      "inputs": {
        "array": "tasks.extract_first_element.first_element"
      },
      "outputs": [
        "unbatched_array"
      ],
      "dependencies": [
        "extract_first_element"
      ]
    },
    {
      "name": "resize_mask_to_original_size",
      "task": "resize_image",
      "displayName": "Resize Image",
      "inputs": {
        "image": "tasks.unbatch_output.unbatched_array",
        "target_width": "tasks.extract_original_hw.orig_width",
        "target_height": "tasks.extract_original_hw.orig_height"
      },
      "outputs": [
        "resized_image"
      ],
      "dependencies": [
        "unbatch_output",
        "extract_original_hw"
      ]
    },
    {
      "name": "visualize_mask",
      "task": "visualize_segmentation_mask",
      "displayName": "Visualize Segmentation Mask",
      "inputs": {
        "mask_array": "tasks.resize_mask_to_original_size.resized_image"
      },
      "outputs": [
        "colored_mask",
        "class_summary"
      ],
      "dependencies": [
        "resize_mask_to_original_size"
      ]
    },
    {
      "name": "process_mask",
      "task": "process_segmentation_mask",
      "displayName": "Process Segmentation Mask",
      "inputs": {
        "mask_array": "tasks.resize_mask_to_original_size.resized_image",
        "keep_class_id": "inputs.keep_class_id"
      },
      "outputs": [
        "processed_mask"
      ],
      "dependencies": [
        "resize_mask_to_original_size"
      ]
    },
    {
      "name": "blur_background",
      "task": "blur_image_with_mask",
      "displayName": "Blur Image with Mask",
      "inputs": {
        "image_array": "tasks.load_image.image",
        "mask_array": "tasks.process_mask.processed_mask",
        "blur_radius": "inputs.blur_radius"
      },
      "outputs": [
        "blurred_image_array"
      ],
      "dependencies": [
        "process_mask",
        "load_image"
      ]
    },
    {
      "name": "final_uint8",
      "task": "convert_array_dtype",
      "displayName": "Convert Array Data Type",
      "inputs": {
        "array": "tasks.blur_background.blurred_image_array",
        "target_dtype": {
          "literal": "uint8"
        }
      },
      "outputs": [
        "converted_array"
      ],
      "dependencies": [
        "blur_background"
      ]
    }
  ],
  "inputs": {
    "image_path": "samples/media/object_detection_sample.jpg",
    "model_repository": "qualcomm/FCN-ResNet50",
    "model_name": "FCN-ResNet50_float.onnx.zip",
    "model_revision": "v0.45.0",
    "base_directory": "models",
    "keep_class_id": 12,
    "blur_radius": 90
  },
  "outputs": {
    "blurred_image": "tasks.final_uint8.converted_array"
  },
